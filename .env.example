# Core
ANTHROPIC_API_KEY=

# Optional: Claude Agent SDK built-ins (default none)
# none | read (Read,Glob,Grep) | full (full claude_code preset — Bash, edits, etc.)
COMPANIO_BUILTIN_TOOLS=none
# Headless only: bypass permission prompts (dangerous if strangers can message the bot)
COMPANIO_BYPASS_PERMISSIONS=false

# Optional: raw SQL against companio.db via MCP (default off)
COMPANIO_SQL_TOOL=false
# Allow INSERT/UPDATE/DELETE/DDL (default read-only SELECT/WITH/EXPLAIN only)
COMPANIO_SQL_WRITE=false

# Telegram
TELEGRAM_BOT_TOKEN=
TELEGRAM_OWNER_ID=

# Slack (Phase 3)
SLACK_BOT_TOKEN=
SLACK_TEAM_ID=

# ClickUp
CLICKUP_API_KEY=
CLICKUP_SPACE_ID=
CLICKUP_MEMBER_ID=

# GitHub (MCP: @modelcontextprotocol/server-github)
# Fine-grained or classic PAT; mapped to GITHUB_PERSONAL_ACCESS_TOKEN for the server.
# See: https://github.com/settings/tokens
GITHUB_TOKEN=

# Discord (Phase 4)
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=

# Webhook (Phase 4)
WEBHOOK_SECRET=
WEBHOOK_PORT=3000

{
  "mcpServers": {
    "slack": {
      "command": "bunx",
      "args": ["-y", "@modelcontextprotocol/server-slack"],
      "env": {
        "SLACK_BOT_TOKEN": "${SLACK_BOT_TOKEN}",
        "SLACK_TEAM_ID": "${SLACK_TEAM_ID}"
      }
    },
    "clickup": {
      "command": "bunx",
      "args": ["-y", "mcp-remote", "https://mcp.clickup.com/mcp", "--header", "Authorization:Bearer ${CLICKUP_API_KEY}"]
    }
  }
}
